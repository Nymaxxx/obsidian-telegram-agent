TZ=Europe/Amsterdam

# Telegram bot
TELEGRAM_BOT_TOKEN=123456:replace_me
# Private chat id is usually a positive integer. Group chat ids are often negative.
TELEGRAM_CHAT_ID=123456789

# Takopi defaults
TAKOPI_DEFAULT_ENGINE=claude
TAKOPI_DEFAULT_PROJECT=obsidian
# Upstream default is "stateless"; "chat" keeps conversation context between messages.
TAKOPI_SESSION_MODE=chat
TAKOPI_SHOW_RESUME_LINE=true
# Upstream default is "trim"; "split" sends long replies as multiple Telegram messages.
TAKOPI_MESSAGE_OVERFLOW=split
TAKOPI_TOPICS_ENABLED=false
TAKOPI_TOPICS_SCOPE=auto

# Claude runner
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_ALLOWED_TOOLS=["Bash","Read","Edit","Write"]
# WARNING: setting this to true lets Claude execute any command without confirmation.
# Only enable if you fully understand the risks and trust your allowed_tools list.
CLAUDE_DANGEROUSLY_SKIP_PERMISSIONS=false
# true only if you want Claude Console/API billing instead of interactive Claude login
CLAUDE_USE_API_BILLING=false
ANTHROPIC_API_KEY=

# Voice transcription (Takopi Telegram voice notes)
VOICE_TRANSCRIPTION_ENABLED=false
VOICE_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_API_KEY=
# Optional local OpenAI-compatible Whisper endpoint
VOICE_TRANSCRIPTION_BASE_URL=
VOICE_TRANSCRIPTION_API_KEY=

# Obsidian headless sync
OBSIDIAN_AUTOSTART_SYNC=false
