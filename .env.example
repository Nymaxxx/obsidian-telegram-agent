# =============================================================================
# obsidian-telegram-agent configuration
# Copy this file to .env and fill in the required values.
# =============================================================================

# --------------- Required ---------------

# Telegram bot token from @BotFather (https://t.me/botfather)
TELEGRAM_BOT_TOKEN=123456:replace_me

# Chat ID where the bot should listen.
# To find yours: message @userinfobot or @RawDataBot on Telegram.
# Private chats use a positive integer; group chats use a negative integer.
TELEGRAM_CHAT_ID=123456789

# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-replace_me

# --------------- Claude -----------------

# Model to use. Sonnet is powerful but expensive (~$3/1M input tokens).
# For everyday vault tasks, claude-haiku-4-5 is ~20x cheaper and fast enough.
CLAUDE_MODEL=claude-sonnet-4-6

# Tools Claude is allowed to use inside the container. The list itself is
# intentionally permissive — narrow Bash patterns like `Bash(mv *)` trigger
# Claude Code's interactive path-safety prompts, which can't be answered in
# a non-interactive (Telegram) session and silently break `mv`.
# The actual security boundary is the deny list below (CLAUDE_DENIED_COMMANDS),
# which Claude Code enforces regardless of permission mode.
CLAUDE_ALLOWED_TOOLS=["Bash","Read","Edit","Write","Glob","Grep","LS","WebFetch"]

# JSON array of Bash command patterns the agent is forbidden to run. These
# go into ~/.claude/settings.json as `permissions.deny` and are enforced
# even if the agent tries to evade via `bash -c`, `find -delete`, etc.
# Defaults block destructive disk and ownership commands. Soft-delete via
# `mv <file> /vault/.trash/` is the supported alternative to `rm` (see
# vault/CLAUDE.md). To extend, replace the list — keep the existing items.
CLAUDE_DENIED_COMMANDS=["Bash(rm *)","Bash(rmdir *)","Bash(chmod *)","Bash(chown *)","Bash(dd *)","Bash(mkfs *)","Bash(shred *)","Bash(sudo *)"]

# Set to true if you use Anthropic API billing (recommended).
# Set to false only if you use interactive Claude login.
CLAUDE_USE_API_BILLING=true

# --------------- Takopi -----------------

# "chat" keeps conversation context between messages (recommended).
# "stateless" starts a fresh Claude session on every message.
TAKOPI_SESSION_MODE=chat

# "split" sends long replies as multiple Telegram messages.
# "trim" truncates long replies to a single message.
TAKOPI_MESSAGE_OVERFLOW=split

# Show the "resume <session_id>" hint line below each reply. Useful while
# debugging; turn off for a cleaner chat.
TAKOPI_SHOW_RESUME_LINE=true

# Default agent and project name. The bundled stack only registers one project
# ("obsidian"), so you almost never need to change these.
TAKOPI_DEFAULT_ENGINE=claude
TAKOPI_DEFAULT_PROJECT=obsidian

# Telegram forum-topic support. Leave disabled unless you use a topic-enabled
# group for the bot.
TAKOPI_TOPICS_ENABLED=false
TAKOPI_TOPICS_SCOPE=auto

# --------------- Voice ------------------

# Enable voice note transcription via Whisper.
VOICE_TRANSCRIPTION_ENABLED=false

# OpenAI API key for voice transcription (required if voice is enabled).
OPENAI_API_KEY=

# Model for transcription. Default works well for most cases.
VOICE_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Optional: use a custom OpenAI-compatible Whisper endpoint instead of OpenAI.
# VOICE_TRANSCRIPTION_BASE_URL=http://your-whisper-host:8080/v1
# VOICE_TRANSCRIPTION_API_KEY=your-key

# --------------- Obsidian Sync ----------

# Start continuous Obsidian Sync on container boot.
# Set to true only after running the one-time sync setup (see README).
OBSIDIAN_AUTOSTART_SYNC=false

# --------------- General ----------------

# Container timezone (affects timestamps in notes).
TZ=Europe/Amsterdam