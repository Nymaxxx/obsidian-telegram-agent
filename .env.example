# === Required ===

# Anthropic API key for Claude Code
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token (from @BotFather)
TAKOPI_TELEGRAM_BOT_TOKEN=123456:ABC-...

# Telegram chat ID where the bot will operate
TAKOPI_TELEGRAM_CHAT_ID=123456789

# GitHub personal access token (repo + workflow scopes)
GH_TOKEN=ghp_...

# === Optional ===

# Comma-separated Telegram user IDs allowed to interact with the bot
# TAKOPI_ALLOWED_USER_IDS=12345,67890

# Auto-clone repos on startup. Format: \
owner/repo:alias
owner/repo2\
# GITHUB_REPOS=myorg/backend:back,myorg/frontend:front

# Claude model to use (default: claude-opus-4-6)
# TAKOPI_CLAUDE_MODEL=claude-opus-4-6

# Allowed tools for Claude (default: Bash,Read,Edit,Write)
# TAKOPI_CLAUDE_ALLOWED_TOOLS=Bash,Read,Edit,Write

# Skip permission prompts -- DANGEROUS, use only in trusted environments
# TAKOPI_CLAUDE_DANGEROUSLY_SKIP_PERMISSIONS=false

# Use API billing instead of Pro subscription (default: true)
# TAKOPI_CLAUDE_USE_API_BILLING=true

# Session mode: chat or oneshot (default: chat)
# TAKOPI_SESSION_MODE=chat

# Show resume line in Telegram (default: true)
# TAKOPI_SHOW_RESUME_LINE=true

# Default engine (default: claude)
# TAKOPI_DEFAULT_ENGINE=claude
